DISCORD_TOKEN=your_discord_token_here

# -- Ollama cloud --
LLM_BACKEND=ollama
OPENAI_COMPATIBLE=ollama.com
LLM_API_KEY=your_ollama_api_key_here
LLM_MODEL=qwen3.5:397b
LLM_MAX_TOKENS=16384
LLM_MAX_THINKING_TOKENS=8192

